# ────────────────────────────────────────────────────────────
#  روزنگار — نمونه‌ی متغیرهای محیطی
#  این فایل را به .env.local کپی کنید و مقادیر واقعی را بگذارید.
#  روی Vercel این مقادیر را در بخش Environment Variables وارد کنید.
# ────────────────────────────────────────────────────────────

# توکن بات تلگرام (از @BotFather)
TELEGRAM_BOT_TOKEN=

# رمز امنیتی وبهوک (یک رشته‌ی تصادفی دلخواه بسازید)
# همین مقدار هنگام ست‌کردن وبهوک هم استفاده می‌شود
TELEGRAM_WEBHOOK_SECRET=

# کلید API گوگل جِمِنای (از https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# مدل جِمِنای مورد استفاده
# gemini-flash-latest همیشه به جدیدترین مدل Flash اشاره می‌کند (رایگان و مالتی‌مودال)
GEMINI_MODEL=gemini-flash-latest

# رشته‌ی اتصال دیتابیس Postgres (از Neon یا Vercel Postgres)
DATABASE_URL=

# آی‌دی عددی چت/کاربرهای مجاز، با کاما جدا شوند (اختیاری؛ خالی = همه مجاز)
ALLOWED_CHAT_IDS=

# آی‌دی کانال بک‌آپ که فایل گزارش آنجا هم ارسال می‌شود (اختیاری)
# مثال: -1001234567890  (بات باید ادمین کانال باشد)
BACKUP_CHANNEL_ID=

# آدرس عمومی سایت روی Vercel (برای ست‌کردن وبهوک)
# مثال: https://roznegar.vercel.app
PUBLIC_BASE_URL=
